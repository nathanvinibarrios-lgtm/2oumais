# Token de acesso à Meta API (obrigatório)
META_ACCESS_TOKEN=seu_access_token_aqui

# ID da conta de anúncios no formato act_XXXXXXXXXX (obrigatório)
META_AD_ACCOUNT_ID=act_000000000000000

# Versão da Meta Graph API (opcional, padrão: v19.0)
META_API_VERSION=v19.0

# Limite de CPL em reais — campanhas acima desse valor serão pausadas (opcional, padrão: 50)
CPL_LIMITE=50

# Modo de simulação: true = não pausa de verdade, apenas loga o que faria (opcional, padrão: false)
DRY_RUN=false
